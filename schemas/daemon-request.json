{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ghostcode://schemas/daemon-request",
  "title": "DaemonRequest",
  "description": "TS Plugin 发送给 Rust Daemon 的操作请求",
  "type": "object",
  "required": ["v", "op", "args"],
  "properties": {
    "v": {
      "type": "integer",
      "const": 1,
      "description": "协议版本号，固定为 1"
    },
    "op": {
      "type": "string",
      "description": "操作名称（如 ping, actor.add, chat.send）"
    },
    "args": {
      "description": "操作参数，任意 JSON 值"
    }
  },
  "additionalProperties": false
}
