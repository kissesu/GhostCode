#!/usr/bin/env bash
# @file codex
# @description Fake codex CLI，用于集成测试
#              输出与真实 codex e --json 兼容的 JSON stream
#              session_id (thread_id) 固定为 "fake-codex-thread-001"
# @author Atlas.oi
# @date 2026-03-04

# 模拟 Codex JSON stream 格式的输出：
# 1. thread.started 事件（Init，包含 thread_id）
# 2. item.completed 事件（AgentMessage）
# 3. thread.completed 事件（Complete）
printf '{"type":"thread.started","thread_id":"fake-codex-thread-001"}\n'
printf '{"type":"item.completed","thread_id":"fake-codex-thread-001","item":{"type":"agent_message","content":"fake codex output"}}\n'
printf '{"type":"thread.completed","thread_id":"fake-codex-thread-001"}\n'
exit 0
